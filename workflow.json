            "id": "edu-0001-4000-8000-000000000006",
            "name": "상세 페이지 요청",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1840,
                350
            ]
        },
        {
            "parameters": {
                "operation": "extractHtmlContent",
                "sourceData": "json",
                "dataPropertyName": "data",
                "extractionValues": {
                    "values": [
                        {
                            "key": "detailTitle",
                            "cssSelector": ".title h3",
                            "returnValue": "text",
                            "returnArray": false
                        },
                        {
