        },
        {
            "parameters": {
                "jsCode": "// 첫 페이지 HTML에서 페이지네이션 링크를 파싱하여\n// 총 페이지 수를 추출한다.\n// fn_egov_link_page(N) 호출 중 최대 N이 총 페이지 수.\n\nconst html = $input.first().json.data;\n\nconst matches = [...html.matchAll(/fn_egov_link_page\\((\\d+)\\)/g)];\nconst pageNumbers = matches.map((m) => parseInt(m[1], 10));\nconst totalPages = pageNumbers.length > 0 ? Math.max(...pageNumbers) : 1;\n\nreturn [{ json: { totalPages } }];"
            },
            "id": "edu-0001-4000-8000-000000000021",
            "name": "총 페이지 수 추출",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                690,
                450
            ]
        },
        {
            "parameters": {
                "url": "https://www.k-startup.go.kr/web/contents/bizpbanc-ongoing.do",
                "options": {
                    "response": {
                        "response": {
                            "responseFormat": "text"
                        }
                    },
                    "pagination": {
                        "pagination": {
                            "paginationMode": "updateAParameterInEachRequest",
                            "parameters": {
                                "parameters": [
                                    {
                                        "type": "qs",
                                        "name": "page",
                                        "value": "={{ $pageCount + 1 }}"
                                    }
                                ]
                            },
                            "paginationCompleteWhen": "other",
                            "completeExpression": "={{ $pageCount + 1 >= $json.totalPages }}",
                            "limitPagesFetched": true,
                            "maxRequests": "={{ $json.totalPages }}",
                            "requestInterval": 1000
                        }
                    }
                }
            },
            "id": "edu-0001-4000-8000-000000000002",
            "name": "목록 페이지 수집",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                910,
                450
            ]
        },
        {
            "parameters": {
                "operation": "extractHtmlContent",
                "sourceData": "json",
                "dataPropertyName": "data",
                "extractionValues": {
                    "values": [
                        {
                            "key": "links",
                            "cssSelector": ".middle a[href*='go_view']",
                            "returnValue": "attribute",
                            "attribute": "href",
                            "returnArray": true
                        },
                        {
                            "key": "titles",
                            "cssSelector": ".middle a[href*='go_view'] p.tit",
                            "returnValue": "text",
                            "returnArray": true
                        },
                        {
                            "key": "fields",
                            "cssSelector": ".middle li .top .flag:not(.day)",
                            "returnValue": "text",
                            "returnArray": true
                        },
                        {
                            "key": "ddays",
                            "cssSelector": ".middle li .flag.day",
                            "returnValue": "text",
                            "returnArray": true
                        },
                        {
                            "key": "agencies",
                            "cssSelector": ".middle li .flag_agency",
                            "returnValue": "text",
                            "returnArray": true
                        }
                    ]
                }
            },
            "id": "edu-0001-4000-8000-000000000003",
            "name": "목록 HTML 파싱",
            "type": "n8n-nodes-base.html",
            "typeVersion": 1.2,
            "position": [
                1130,
                450
            ]
        },
        {
            "parameters": {
                "jsCode": "// HTML 노드가 추출한 배열 데이터에서 공고 ID를 파싱하고\n// 상세 크롤링을 위한 아이템 목록을 생성한다.\n//\n// CSS 선택자로는 href=\"javascript:go_view(176429)\"에서\n// 숫자 ID만 추출하는 것이 불가능하므로 정규식 사용.\n\nconst items = $input.all();\nconst announcements = [];\n\nfor (const item of items) {\n  const links = item.json.links || [];\n  const titles = item.json.titles || [];\n  const fields = item.json.fields || [];\n  const ddays = item.json.ddays || [];\n  const agencies = item.json.agencies || [];\n\n  for (let i = 0; i < links.length; i++) {\n    const href = links[i] || '';\n    const match = href.match(/go_view\\((\\d+)\\)/);\n    if (!match) continue;\n\n    announcements.push({\n      json: {\n        pbancSn: match[1],\n        title: (titles[i] || '').trim(),\n        field: (fields[i] || '').trim(),\n        dday: (ddays[i] || '').trim(),\n        agency: (agencies[i] || '').trim(),\n        detailUrl: `https://www.k-startup.go.kr/web/contents/bizpbanc-ongoing.do?schM=view&pbancSn=${match[1]}`,\n      },\n    });\n  }\n}\n\n// 중복 제거 (페이지 간 중복 가능)\nconst seen = new Set();\nconst unique = announcements.filter((a) => {\n  if (seen.has(a.json.pbancSn)) return false;\n  seen.add(a.json.pbancSn);\n  return true;\n});\n\n// 결과 누적용 static data 초기화\nconst staticData = $getWorkflowStaticData('global');\nstaticData.results = [];\n\nreturn unique;"
            },
            "id": "edu-0001-4000-8000-000000000004",
            "name": "공고 ID 추출",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
