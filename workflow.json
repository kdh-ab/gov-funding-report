                        {
                            "key": "contentText",
                            "cssSelector": ".box .box_inner",
                            "returnValue": "text",
                            "returnArray": false
                        },
                        {
                            "key": "fileNames",
                            "cssSelector": ".board_file li a.file_bg",
                            "returnValue": "text",
                            "returnArray": true
                        },
                        {
                            "key": "fileUrls",
